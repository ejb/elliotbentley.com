---
import MainHead from '../components/MainHead.astro';
import Nav from '../components/Nav.astro';
import AssetCarousel from '../components/AssetCarousel.tsx';
import BackgroundAnimation from '../components/BackgroundAnimation.svelte';
import SiteFooter from '../components/SiteFooter.astro';

// page
let title = 'Elliot Bentley';
let description = 'Visual Journalist & Game Dev';

import portfolio from '../data/portfolio.json';
const portfolioItems = portfolio.filter(d => d.major).slice(0, 5);

let allPosts = Astro.fetchContent('./blog/*.md');
allPosts.sort((a, b) => new Date(b.date) - new Date(a.date));
let firstPage = allPosts.slice(0, 2);
---

<style lang="sass">

  body {
    color: var(--white);
    background: var(--black);
    font-family: 'Crimson Text', serif;
    font-size: 24px;
    text-shadow: 0 1px 2px rgba(20,20,20,0.1);
    margin: 0;
    
  }
  a, a:visited {
    color: var(--white);
    transition: background 200ms;
  }

  header {
    position: relative;
    padding-bottom: 1px;
    min-height: 100vh;
  }

  :global(.title) {
    color: var(--white) !important;
    a {
      opacity: 0.5;
      &:hover {
        opacity: 0.8;
      }
    }

  }

  section {
    max-width: 800px;
    margin: 0 auto;
    margin-bottom: 0.7em;
    padding: 10px;
    margin-top: 0.8em;
  }
  header {
    // margin-top: 2.8em;
  }
  p {
    margin-top: 0;
    line-height: 1.4em;
  }
  .ps-link {
    font-style: italic;  
  }
  ul, li {
    padding: 0;
    margin: 0;
    list-style-type: none;
  }
  li {
    margin-bottom: 0.7em;
  }
  .contact ul {
    display: flex;
  }
  .contact li {
    margin-right: 1em;
  }

  .portfolios {
    @media (max-width: 900px) {
      overflow-x: hidden;
    }
  }

  .contact {
    img {
      width: 40px;
      height: 40px;
      filter: invert(100%);
    }
    a img {
      opacity: 0.6;
      transition: opacity 200ms;
    }
    a:hover {
      background: none;
      img {
        opacity: 0.8;
      }
    }
  }



</style>

<html>
  <head>
    <title>{title}</title>
    <MainHead
      title={title}
      description={description}
      image={''}
      canonicalURL={Astro.request.canonicalURL.href}
    />
  </head>

  <body>


    <main class="wrapper">
      <header>

        <Nav />

        <section>

          <p>I'm a <a href="/portfolio">visual journalist</a> and <a href="https://pawprints.itch.io/">amateur game developer</a>. I've worked at The Wall Street Journal’s graphics department since 2014.</p>
          <p>I offer coaching sessions to students and early career journalists as part of the <a href="https://journalismmentors.com/mentors">Media Mentors</a> programme.</p>
          <p>In 2013 I created <a href="https://otranscribe.com">oTranscribe</a>, a web app for transcription that’s  used by thousands of people. It's now operated by <a href="https://www.muckrock.com">MuckRock</a>.</p>

        </section>


        <section class="contact">
          <ul>
            <li><a href="mailto:mail@elliotbentley.com">
              <image src="/images/envelope.svg" alt="Email">
            </a></li>
            <li>
              <a href="https://twitter.com/elliot_bentley">
                <image src="/images/twitter.svg" alt="Twitter">
              </a>
            </li>
            <li><a href="https://github.com/ejb">
              <image src="/images/github.svg" alt="GitHub">
            </a></li>
          </ul>
        </section>


        <BackgroundAnimation:load />

      </header>

      <section class="portfolios">
        <h2>Visual journalism</h2>

        <p>I joined the Wall Street Journal’s graphics department in 2014 and have produced dozens of graphics in the years since. My speciality is web graphics — interactives, news apps and data visualisations. <a href="/portfolio" class="ps-link">View full portfolio »</a></p>

        <AssetCarousel assets={portfolioItems.map(p => p.media.find(m => m.type === 'image'))} />

      </section>

      <section class="blog">
        <div class="inner">
          <h2>Blog Posts</h2>
          <ul>
            {firstPage.map(p => {
              return (<li>
                <a href={p.url}>{p.title}</a>
              </li>)
            })}
            <li><a href="/blog" class="ps-link">More blog posts »</a></li>
          </ul>
        </div>
      </section>

    </main>

    <SiteFooter />
  </body>
</html>
